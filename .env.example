# --- General ---
# allowed: client, all-in-one
OBSERVER_MODE=client
# allowed: error, warn, info, debug, trace
OBSERVER_LOG_LEVEL=info

# --- Client mode ---
OBSERVER_BASE_METRICS_URL=https://metrics.example.com
OBSERVER_BASE_COMMANDS_URL=https://commands.example.com
OBSERVER_API_KEY=your-api-key
# allowed: 1-15 seconds
OBSERVER_ACTIVE_STREAMING_INTERVAL_SECS=1
# allowed: 10-300 seconds
OBSERVER_INACTIVE_STREAMING_INTERVAL_SECS=10
# allowed: 1-60 seconds
OBSERVER_COMMAND_POLL_INTERVAL_SECS=5
# allowed: 60-86400 seconds (1 minute to 24 hours)
OBSERVER_SPEEDTEST_INTERVAL_SECS=3600

# --- All-in-one mode ---
# allowed: 0-65535
# OBSERVER_PORT=8080
