[server]
base_metrics_url  = "https://example.com/api/metrics"
base_commands_url = "https://example.com/api/commands"
base_docker_url   = "https://example.com/api/docker"
api_key           = "your-api-key-here"

[intervals]
metric_secs       = 5    # 2–60 seconds
command_poll_secs = 5    # 2–60 seconds
speedtest_secs    = 300  # 60–86400 seconds (5 minutes)
docker_secs       = 10   # 10–60 seconds
